# Verejné — bezpečné na klient
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=ey...

# Service role — LEN server-side (route handlers, server components). NIKDY do klient bundle.
SUPABASE_SERVICE_ROLE_KEY=ey...

# Apify
APIFY_TOKEN=apify_api_...
# Zdieľaný tajný token, ktorý posiela Apify v query parametri `secret`
APIFY_WEBHOOK_SECRET=zmen-ma-na-nahodny-retazec

# Anthropic (Claude) — automatická extrakcia detailov látok z webov dodávateľov
ANTHROPIC_API_KEY=sk-ant-...

# Tajný token pre Vercel Cron backfill extrakcie látok (/api/cron/extract-fabrics)
CRON_SECRET=zmen-ma-na-nahodny-retazec
